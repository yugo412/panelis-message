{
  "name": "panelis-php/message",
  "description": "Manage system messages, notifications, and user communications.",
  "keywords": [
    "panelis"
  ],
  "require": {
    "filament/filament": "^5.0",
    "laravel/framework": "^13.0"
  },
  "autoload": {
    "psr-4": {
      "Panelis\\Message\\": "src/",
      "Panelis\\Message\\Database\\Factories\\": "database/factories/",
      "Panelis\\Message\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Panelis\\Message\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Panelis\\Message\\Providers\\MessageServiceProvider"
      ]
    },
    "panelis": {
      "plugins": [
        "Panelis\\Message\\Plugins\\MessagePlugin"
      ]
    }
  },
  "require-dev": {
    "laravel/pint": "^1.29"
  }
}
